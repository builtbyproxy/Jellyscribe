---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import { latestRelease } from '../lib/releases';

const repoUrl = 'https://github.com/builtbyproxy/jellyfin-plugin-letterboxd';
const manifestUrl = 'https://lbsync-telemetry.lachlanbyoung.workers.dev/manifest.json';
const fileTransformationManifestUrl = 'https://www.iamparadox.dev/jellyfin/plugins/manifest.json';
const fileTransformationRepoUrl = 'https://github.com/IAmParadox27/jellyfin-plugin-file-transformation';
const releasesUrl = `${repoUrl}/releases`;
const latestReleaseUrl = `${repoUrl}/releases/latest`;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const localReleasesUrl = `${base}/releases`;
const latestReleaseAnchor = `${localReleasesUrl}#${latestRelease.anchor}`;

const flowSteps = [
  { title: 'Real-time', body: 'Logged the moment credits roll, not on the next scheduled run, rewatches marked automatically.' },
  { title: 'Daily catch-up', body: 'A scheduled sweep mops up anything missed, an offline watch, a skipped episode, a restart mid-file.' },
  { title: 'TMDb matching', body: 'No name-guessing. Foreign titles, unusual cuts, absolute-numbered anime, all matched by ID.' },
];

const travelRows = [
  { icon: 'star', title: 'Ratings, both ways', aside: '', stars: true, body: "Jellyfin's 0–10 becomes Letterboxd's half-stars or Serializd's 1–10 scale. It flows back too, rate something externally and Jellyfin picks it up, even for titles you never logged a watch for." },
  { icon: 'heart', title: 'Favorites → likes', aside: 'zero clicks', stars: false, body: "Heart it in Jellyfin. It's liked over there by the next sync, no extra step." },
  { icon: 'pencil', title: 'Written reviews', aside: '', stars: false, stamp: true, body: 'Compose from the Jellyfin dashboard with rating, spoiler tag, rewatch flag, even a specific episode, and it posts exactly as written.' },
  { icon: 'import', title: 'Watched status, too', aside: '', stars: false, body: "Already marked something watched on Letterboxd or Serializd? Jellyfin picks that up too, no need to log it twice." },
  { icon: 'list', title: 'Watchlist, mirrored', aside: '', stars: false, body: 'Your watchlist becomes a Jellyfin collection and playlist on its own, and mirrors into your Jellyseerr watchlist too. Anything missing gets requested through Jellyseerr, attributed to you.' },
];

const infraCards = [
  { title: 'Multi-user, multi-account', body: "Every Jellyfin user links their own Letterboxd and Serializd logins from the sidebar, no admin access needed. A shared profile just means more than one diary gets the same entry." },
  { title: 'Retries with judgment', body: 'Already-synced titles never re-hit the API. Failures retry first when limits ease; three strikes and an item waits for the next run instead of hammering forever.' },
  { title: 'Self-healing auth', body: 'A stale login re-authenticates and retries on its own, on either service. No manual re-login, ever.' },
  { title: 'TV sync just works', body: "Letterboxd sometimes needs a cookie pasted in to get past a login wall. Serializd never does, so TV sync has nothing to babysit." },
  { title: 'Isolated by design', body: 'A Serializd hiccup never blocks the Letterboxd path, or vice versa. Two independent syncs, not one fragile pipeline.' },
  { title: 'Tells you what happened', body: "Every send, skip, and failure lands in the dashboard's searchable log, or one click ships it to the developer with a reference code.", ticker: true },
];
---

<Layout title="Jellyscribe for Jellyfin" description="Jellyscribe writes what you finish watching in Jellyfin into the diaries you already keep, Letterboxd for film, Serializd for TV.">
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Jellyscribe',
    description: 'Jellyscribe writes what you finish watching in Jellyfin into the diaries you already keep, Letterboxd for film, Serializd for TV.',
    applicationCategory: 'MultimediaApplication',
    operatingSystem: 'Jellyfin 10.11+',
    url: 'https://jellyscribe.dev/',
    downloadUrl: releasesUrl,
    softwareVersion: latestRelease.version,
    author: { '@type': 'Person', name: 'Lachlan Young' },
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  })} />
  <header class="site-header">
    <div class="container nav">
      <div class="brand-group">
        <a class="brand" href="/" aria-label="Jellyscribe home">
          <svg class="brand-mark" width="22" height="22" viewBox="0 0 64 64" aria-hidden="true">
            <rect width="64" height="64" rx="12" fill="var(--bg-elev-2)"/>
            <path d="M20 15 H44 V51 L32 40 L20 51 Z" fill="var(--gold)"/>
          </svg>
          <span class="brand-name">Jellyscribe</span>
        </a>
        <span class="brand-by">
          by <a
            href="https://lachlanyoung.dev/?utm_source=jellyfin-plugin-letterboxd&utm_medium=site&utm_campaign=author-link"
            class="brand-author"
            rel="author"
            data-plausible-event="Author Link: Click"
          >Lachlan Young</a>
        </span>
      </div>
      <nav class="nav-links">
        <a href="#features">Features</a>
        <a href="#install">Install</a>
        <a href="#setup">Setup</a>
        <a href={localReleasesUrl}>Releases</a>
        <a href={repoUrl} rel="noopener">GitHub</a>
      </nav>
    </div>
  </header>

  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <div class="eyebrow">
          <span class="eyebrow-dot"></span>
          Jellyfin plugin
        </div>
        <h1>
          Every watch,<br />
          written to <span class="accent">your diary</span>.
        </h1>
        <p class="lede">
          Jellyscribe logs what you finish watching in Jellyfin straight into the diaries you
          already keep, Letterboxd for film, Serializd for TV. Real-time, multi-user, and
          quietly resilient to the rough edges of scraping.
        </p>
        <div class="hero-cta">
          <a class="btn btn-primary" href="#install">Install plugin</a>
          <a class="btn btn-secondary" href={repoUrl} rel="noopener">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 0 0 5.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/></svg>
            View on GitHub
          </a>
        </div>
        <div class="install-pill" data-pill>
          <span class="install-pill-label">Manifest URL</span>
          <code class="install-pill-url">{manifestUrl}</code>
          <button class="install-pill-btn" type="button" data-copy={manifestUrl} aria-label="Copy manifest URL">
            <span class="copy-icon" aria-hidden="true">⧉</span>
            <span class="copy-text">Copy</span>
          </button>
        </div>
        <a class="latest-link" href={latestReleaseAnchor}>
          <span class="latest-dot" aria-hidden="true"></span>
          <span class="latest-label">Latest</span>
          <span class="latest-version">v{latestRelease.version}</span>
          <span class="latest-sep" aria-hidden="true">·</span>
          <span class="latest-date">{latestRelease.dateLabel}</span>
          <span class="latest-arrow">What's new <span aria-hidden="true">&rarr;</span></span>
        </a>
      </div>

      <div class="hero-art" aria-hidden="true">
        <div class="card-stack">
          <div class="card card-1">
            <div class="card-head">
              <span class="mini-dots"><i></i><i></i><i></i></span>
              <span class="card-title">Recent sync</span>
            </div>
            <ul class="diary">
              <li><span class="diary-title">Inception<span class="diary-dest">Letterboxd</span></span><span class="diary-stars">★★★★★</span></li>
              <li><span class="diary-title">The Bear <span class="diary-ep">S3E7</span><span class="diary-dest">Serializd</span></span><span class="diary-stars">★★★★½</span></li>
              <li><span class="diary-title">Avatar<span class="diary-dest">Letterboxd</span></span><span class="diary-stars">★★★★</span></li>
              <li><span class="diary-title">Severance <span class="diary-ep">S2E1</span><span class="diary-dest">Serializd</span></span><span class="diary-stars">★★★★</span></li>
            </ul>
            <div class="card-foot">
              <span class="pulse"></span>
              Synced just now
            </div>
          </div>
          <div class="card card-2">
            <div class="stat">
              <div class="stat-num">1,284</div>
              <div class="stat-label">watches synced</div>
            </div>
            <div class="stat">
              <div class="stat-num">2</div>
              <div class="stat-label">diaries kept</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="features">
    <div class="container">
      <div class="section-head">
        <h2>Everything you'd expect. And a few you wouldn't.</h2>
        <p>Talks to Letterboxd's current JSON API first, with a scraping fallback for when it's needed. Serializd's API needs none of that. Either way, the stitches stay hidden.</p>
      </div>

      <div class="scribe-block">
        <div class="grid6">
          <div class="feat-head">
            <div class="head-copy">
              <div class="feat-eyebrow">How it works</div>
              <h3>One real-time engine, film and TV alike.</h3>
              <p>Finish something in Jellyfin, and it's logged before you've picked what's next. One matching layer, one dedupe history, one daily sweep, Letterboxd and Serializd both run through it.</p>
            </div>
            <span class="status-pill"><span class="dot"></span>Syncing live</span>
          </div>

          <div class="flow-row">
            <div class="flow-line">
              <svg class="flow-dot" viewBox="0 0 12 12" fill="var(--gold)"><path d="M2.5 1.2 L10.5 6 L2.5 10.8 Z"/></svg>
              <svg class="flow-dot" viewBox="0 0 12 12" fill="var(--gold)"><path d="M2.5 1.2 L10.5 6 L2.5 10.8 Z"/></svg>
            </div>
            {flowSteps.map((step, i) => (
              <div class="flow-step">
                <div class="flow-step-head">
                  <h4>{step.title}</h4>
                  {i === 0 && <span class="status-pill"><span class="dot"></span>Live</span>}
                </div>
                <p>{step.body}</p>
              </div>
            ))}
            <div class="flow-note margin-note">
              <svg width="34" height="24" viewBox="0 0 34 24" fill="none" stroke="var(--ink)" stroke-width="1.6" stroke-linecap="round"><path d="M2,22 Q10,4 30,3"/><path d="M22,2 L30,3 L26,10"/></svg>
              usually before the credits finish
            </div>
          </div>
        </div>
      </div>

      <div class="scribe-block scribe-divider">
        <div class="grid6">
          <div class="feat-head">
            <div class="head-copy">
              <div class="feat-eyebrow">What moves with it</div>
              <h3>Not just the watch. The whole entry.</h3>
              <p>Rating, like, review, watchlist, all of it travels both directions, automatically.</p>
            </div>
          </div>

          {travelRows.map((row) => (
            <div class="travel-row">
              <div class="row-divider"></div>
              <div class="label">
                <span class={`travel-icon ${row.icon === 'heart' ? 'beat' : ''}`}><Icon name={row.icon} size={16} /></span>
                <div class="label-text">
                  <h4>{row.title}{row.aside && <span class="aside">{row.aside}</span>}</h4>
                  {row.stars && <span class="row-stars"><span>★</span><span>★</span><span>★</span><span>★</span><span>½</span></span>}
                </div>
              </div>
              <div class="desc">
                <p>{row.body}{row.stamp && <span class="stamp">✓ noted</span>}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="scribe-block scribe-divider">
        <div class="grid6">
          <div class="feat-head">
            <div class="head-copy">
              <div class="feat-eyebrow">Why trust it unattended</div>
              <h3>Runs like infrastructure, not a script. <span class="aside">no duct tape, promise</span></h3>
              <p>This thing runs for months without anyone watching it. It has to be honest about failure, not just good at success.</p>
            </div>
            <span class="status-pill"><span class="dot"></span>System healthy</span>
          </div>

          <div class="infra-grid">
            {infraCards.map((card) => (
              <div class="infra-card">
                <h4>{card.title}</h4>
                <p>{card.body}</p>
                {card.ticker && (
                  <>
                    <span class="log-ticker"><span class="dot"></span>Severance S2E1 · just now</span>
                    <span class="aside">we keep receipts</span>
                  </>
                )}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="install">
    <div class="container">
      <div class="section-head">
        <h2>Install</h2>
        <p>Two paths. Use the plugin repository for automatic updates, or install manually from a release.</p>
      </div>

      <div class="install-grid">
        <div class="install-card install-card-featured">
          <div class="install-badge">Recommended</div>
          <h3>Plugin repository</h3>
          <ol class="steps">
            <li>Open <strong>Dashboard &rarr; Plugins &rarr; Repositories</strong> in Jellyfin.</li>
            <li>Add the <strong>File Transformation</strong> repository (needed for the sidebar link to appear):
              <div class="install-pill install-pill-inline" data-pill>
                <code class="install-pill-url">{fileTransformationManifestUrl}</code>
                <button class="install-pill-btn" type="button" data-copy={fileTransformationManifestUrl} aria-label="Copy File Transformation manifest URL">
                  <span class="copy-icon" aria-hidden="true">⧉</span>
                  <span class="copy-text">Copy</span>
                </button>
              </div>
            </li>
            <li>Add the <strong>Jellyscribe</strong> repository:
              <div class="install-pill install-pill-inline" data-pill>
                <code class="install-pill-url">{manifestUrl}</code>
                <button class="install-pill-btn" type="button" data-copy={manifestUrl} aria-label="Copy manifest URL">
                  <span class="copy-icon" aria-hidden="true">⧉</span>
                  <span class="copy-text">Copy</span>
                </button>
              </div>
            </li>
            <li>Open the <strong>Catalog</strong>, install <strong>File Transformation</strong>, then install <strong>Jellyscribe</strong>.</li>
            <li>Restart Jellyfin, then hard-refresh the web UI (Ctrl/Cmd + Shift + R) so the sidebar link loads.</li>
          </ol>
        </div>

        <div class="install-card">
          <h3>Manual install</h3>
          <ol class="steps">
            <li>Install the <a href={fileTransformationRepoUrl} rel="noopener">File Transformation plugin</a> first, required for the Letterboxd sidebar link.</li>
            <li>Download the latest Jellyscribe ZIP from <a href={latestReleaseUrl} rel="noopener">Releases</a>.</li>
            <li>Extract <code>Jellyscribe.dll</code> and <code>HtmlAgilityPack.dll</code> into your Jellyfin plugins directory.</li>
            <li>Restart Jellyfin.</li>
          </ol>
          <a class="text-link" href={releasesUrl} rel="noopener">Browse all releases &rarr;</a>
        </div>
      </div>

      <div class="reqs">
        <div class="req"><span class="req-label">Jellyfin</span><span class="req-value">10.11 or newer</span></div>
        <div class="req"><span class="req-label">Requires</span><span class="req-value">A Letterboxd and/or Serializd account</span></div>
        <div class="req"><span class="req-label">For sidebar link</span><span class="req-value"><a href={fileTransformationRepoUrl} rel="noopener">File Transformation plugin</a></span></div>
        <div class="req"><span class="req-label">License</span><span class="req-value">MIT</span></div>
      </div>
    </div>
  </section>

  <section id="setup">
    <div class="container">
      <div class="section-head">
        <h2>Setup in under a minute</h2>
        <p>Once the plugin is installed, each user links their own Letterboxd account, Serializd account, or both, from the Jellyfin dashboard.</p>
      </div>

      <ol class="setup-steps">
        <li>
          <div class="step-num">1</div>
          <div class="step-body">
            <h3>Open the plugin page</h3>
            <p>Go to <strong>Dashboard &rarr; Plugins &rarr; Jellyscribe</strong>, then switch to the <strong>Letterboxd</strong> or <strong>TV / Serializd</strong> tab.</p>
          </div>
        </li>
        <li>
          <div class="step-num">2</div>
          <div class="step-body">
            <h3>Add an account</h3>
            <p>Click <strong>+ Add Account</strong>, pick a Jellyfin user, and enter their Letterboxd or Serializd credentials. Check <strong>Enabled</strong>.</p>
          </div>
        </li>
        <li>
          <div class="step-num">3</div>
          <div class="step-body">
            <h3>Watch something</h3>
            <p>That's it. Finish a film or an episode in Jellyfin and check your diary. A daily scheduled sync catches anything missed.</p>
          </div>
        </li>
      </ol>

      <div class="tip">
        <strong>Seeing Cloudflare 403s?</strong>
        <p>Log into Letterboxd in your browser, grab the <code>Cookie</code> header from DevTools, and paste it into the plugin's <strong>Raw Cookies</strong> field. The plugin will use the official API first and only fall back to scraping when needed.</p>
      </div>
    </div>
  </section>

  <footer class="site-footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <svg class="brand-mark" width="18" height="18" viewBox="0 0 64 64" aria-hidden="true">
          <rect width="64" height="64" rx="12" fill="var(--bg-elev-2)"/>
          <path d="M20 15 H44 V51 L32 40 L20 51 Z" fill="var(--gold)"/>
        </svg>
        <span>Jellyscribe</span>
      </div>
      <div class="footer-links">
        <a href={repoUrl} rel="noopener">GitHub</a>
        <a href={releasesUrl} rel="noopener">Releases</a>
        <a href={`${repoUrl}/issues`} rel="noopener">Issues</a>
        <a href="https://letterboxd.com/" rel="noopener">Letterboxd</a>
        <a href="https://www.serializd.com/" rel="noopener">Serializd</a>
        <a href="https://jellyfin.org/" rel="noopener">Jellyfin</a>
      </div>
      <div class="footer-meta">
        <span>Unofficial. Not affiliated with Letterboxd, Serializd, or Jellyfin.</span>
      </div>
    </div>
  </footer>
</Layout>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: rgba(11,13,16,0.75);
    backdrop-filter: saturate(140%) blur(10px);
    -webkit-backdrop-filter: saturate(140%) blur(10px);
    border-bottom: 1px solid var(--border);
  }
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--text);
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .brand:hover { text-decoration: none; }
  .brand-name { font-size: 15px; }

  .brand-group {
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }
  .brand-by {
    font-size: 13px;
    color: var(--text-dim);
    font-weight: 400;
  }
  .brand-author {
    color: var(--text-dim);
    border-bottom: 1px dotted currentColor;
  }
  .brand-author:hover {
    color: var(--text);
    text-decoration: none;
  }
  @media (max-width: 640px) {
    .brand-by { display: none; }
  }

  .brand-mark {
    flex-shrink: 0;
    display: block;
    border-radius: 5px;
  }

  .nav-links {
    display: flex;
    gap: 22px;
    font-size: 14px;
  }
  .nav-links a {
    color: var(--text-dim);
  }
  .nav-links a:hover { color: var(--text); text-decoration: none; }

  @media (max-width: 640px) {
    .nav-links a:nth-child(-n+2) { display: none; }
  }

  .hero { padding: 80px 0 60px; }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 64px;
    align-items: center;
  }
  .hero-copy, .hero-art { min-width: 0; }
  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; gap: 40px; }
    .hero { padding: 56px 0 48px; }
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    padding: 6px 12px;
    border-radius: 999px;
    margin-bottom: 20px;
  }
  .eyebrow-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--gold);
    box-shadow: 0 0 12px rgba(232,184,75,0.5);
  }

  .accent {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    background: linear-gradient(90deg, var(--gold), var(--gold-bright));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .lede {
    font-size: 1.125rem;
    max-width: 560px;
    color: var(--text-dim);
  }

  .hero-cta {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 28px;
  }

  .install-pill {
    margin-top: 20px;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    padding: 8px 8px 8px 14px;
    border-radius: 999px;
    max-width: 100%;
  }
  .install-pill-inline { margin-top: 10px; display: flex; }
  .install-pill-label {
    font-size: 12px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding-right: 6px;
    border-right: 1px solid var(--border);
    white-space: nowrap;
  }
  .install-pill-url {
    background: transparent;
    border: 0;
    padding: 0;
    color: var(--text);
    font-size: 13px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex: 1;
    min-width: 0;
    max-width: min(60vw, 440px);
  }
  @media (max-width: 640px) {
    .install-pill { padding: 6px 6px 6px 12px; gap: 8px; }
    .install-pill-label { display: none; }
    .install-pill-url { max-width: min(50vw, 240px); font-size: 12px; }
    .install-pill-btn { padding: 5px 10px; font-size: 12px; }
  }
  .install-pill-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--bg-elev-2);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 6px 12px;
    border-radius: 999px;
    font: inherit;
    font-size: 13px;
    cursor: pointer;
    transition: background 120ms ease, color 120ms ease;
