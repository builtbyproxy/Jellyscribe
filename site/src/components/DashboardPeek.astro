---
const bars = [3, 5, 2, 7, 4, 6, 8, 4, 9, 6, 5, 7, 10, 8];
const max = Math.max(...bars);

const activity = [
  { title: 'Oppenheimer',              year: '2023', status: 'synced',  time: '2m ago' },
  { title: 'Top Gun: Maverick',        year: '2022', status: 'synced',  time: '11m ago' },
  { title: 'Spider-Man: No Way Home',  year: '2021', status: 'rewatch', time: '1h ago' },
  { title: 'Forrest Gump',             year: '1994', status: 'synced',  time: '3h ago' },
];
---

<div class="dash" aria-hidden="true">
  <div class="dash-head">
    <div>
      <div class="dash-title">Jellyscribe</div>
      <div class="dash-sub">Dashboard · @8bitproxy</div>
    </div>
    <div class="dash-actions">
      <span class="dash-pill dash-pill-ok"><span class="pill-dot"></span> Healthy</span>
      <span class="dash-btn">Run sync now</span>
    </div>
  </div>

  <div class="dash-stats">
    <div class="stat-cell">
      <div class="stat-num">1,284</div>
      <div class="stat-label">Synced</div>
    </div>
    <div class="stat-cell">
      <div class="stat-num stat-num-blue">27</div>
      <div class="stat-label">Rewatches</div>
    </div>
    <div class="stat-cell">
      <div class="stat-num stat-num-orange">3</div>
      <div class="stat-label">Skipped</div>
    </div>
    <div class="stat-cell">
      <div class="stat-num stat-num-dim">0</div>
      <div class="stat-label">Failed</div>
    </div>
  </div>

  <div class="dash-row">
    <div class="dash-card dash-chart">
      <div class="dash-card-head">
        <span>Syncs · last 14 days</span>
        <span class="dash-card-meta">+18%</span>
      </div>
      <div class="chart">
        {bars.map((b) => (
          <span class="chart-bar" style={`--h:${(b/max)*100}%`}></span>
        ))}
      </div>
    </div>

    <div class="dash-card dash-activity">
      <div class="dash-card-head">
        <span>Recent activity</span>
        <span class="dash-card-meta">Live</span>
      </div>
      <ul class="activity">
        {activity.map((a) => (
          <li>
            <span class={`act-status act-${a.status}`}>{a.status === 'rewatch' ? '↻' : '✓'}</span>
            <span class="act-title">{a.title}</span>
            <span class="act-year">{a.year}</span>
            <span class="act-time">{a.time}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</div>

<style>
  .dash {
    background: linear-gradient(180deg, var(--bg-elev), var(--bg-elev-2));
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  @media (max-width: 560px) {
    .dash { padding: 20px; gap: 16px; }
    .dash-head { flex-wrap: wrap; }
    .stat-num { font-size: 20px; }
    .stat-cell { padding: 12px 14px; }
    .dash-btn { display: none; }
  }

  .dash-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }
  .dash-title {
    font-size: 14px;
    font-weight: 700;
    color: var(--text);
  }
  .dash-sub {
    font-size: 12px;
    color: var(--text-dim);
  }
  .dash-actions { display: inline-flex; gap: 8px; align-items: center; }
  .dash-pill {
    font-size: 11px;
    padding: 4px 10px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(122,154,118,0.1);
    color: var(--ledger-green);
    border: 1px solid rgba(122,154,118,0.25);
  }
  .pill-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--ledger-green);
    box-shadow: 0 0 0 0 rgba(122,154,118,0.6);
    animation: pulse 1.8s ease-out infinite;
  }
  .dash-btn {
    font-size: 11px;
    padding: 5px 11px;
    border-radius: 8px;
    background: var(--brass);
    color: #1c1409;
    font-weight: 600;
  }

  .dash-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
  }
  .stat-cell {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 16px 18px;
  }
  .stat-num {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--brass);
    margin-bottom: 4px;
  }
  .stat-num-blue { color: var(--brass-bright); }
  .stat-num-orange { color: var(--text-dim); }
  .stat-num-dim { color: var(--text-dim); }
  .stat-label {
    font-size: 10px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .dash-row {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: 10px;
  }
  @media (max-width: 720px) {
    .dash-row { grid-template-columns: 1fr; }
    .dash-stats { grid-template-columns: repeat(2, 1fr); }
  }

  .dash-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 16px 18px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .dash-card-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 11px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .dash-card-meta {
    font-family: var(--font-mono);
    color: var(--ledger-green);
    font-size: 10px;
  }

  .chart {
    display: flex;
    align-items: flex-end;
    gap: 5px;
    height: 96px;
  }
  .chart-bar {
    flex: 1;
    height: var(--h);
    background: linear-gradient(180deg, var(--brass), rgba(201,144,60,0.2));
    border-radius: 3px 3px 0 0;
    min-height: 3px;
  }

  .activity {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .activity li {
    display: grid;
    grid-template-columns: 18px minmax(0, 1fr) auto auto;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    padding: 4px 0;
    border-bottom: 1px dashed var(--border);
  }
  @media (max-width: 420px) {
    .activity li { grid-template-columns: 18px minmax(0, 1fr) auto; }
    .act-year { display: none; }
  }
  .activity li:last-child { border-bottom: 0; }
  .act-status {
    width: 18px; height: 18px;
    border-radius: 50%;
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 10px;
    font-weight: 700;
  }
  .act-synced { background: rgba(122,154,118,0.15); color: var(--ledger-green); }
  .act-rewatch { background: rgba(201,144,60,0.15); color: var(--brass); }
  .act-title { color: var(--text); font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .act-year { color: var(--text-dim); font-family: var(--font-mono); font-size: 11px; }
  .act-time { color: var(--text-dim); font-size: 11px; }
</style>
